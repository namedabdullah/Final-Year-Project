# ============================================================================
# SAMpai — environment configuration template
# ----------------------------------------------------------------------------
# Copy this file to `.env` in the repository root and fill in the values marked
# with <...>. Defaults below assume the data stores started via
# `sampai/docker/docker-compose.yml` (the `data` profile) on localhost.
#
# Secrets (API keys, passwords, JWT secret, R2 credentials) MUST be provided —
# the AI features call external services and the app will not work without them.
# ============================================================================

# ── API server ──────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=9621
WEBUI_TITLE=The Learning SAMpai
WEBUI_DESCRIPTION=AI-powered classroom learning

# ── LLM provider ──────────────────────────────────────────────────────────────
# Provider binding: openai | azure_openai | anthropic | gemini | ollama | ...
LLM_BINDING=openai
LLM_MODEL=gpt-4o-mini
LLM_BINDING_HOST=https://api.openai.com/v1
LLM_BINDING_API_KEY=<your-llm-api-key>
MAX_ASYNC=4
MAX_PARALLEL_INSERT=2

# ── Embeddings ────────────────────────────────────────────────────────────────
EMBEDDING_BINDING=openai
EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_DIM=3072
EMBEDDING_BINDING_HOST=https://api.openai.com/v1
EMBEDDING_BINDING_API_KEY=<your-embedding-api-key>

# ── Reranking (optional; set to a provider to enable) ─────────────────────────
RERANK_BINDING=null

# ── Storage backends ──────────────────────────────────────────────────────────
# These select the LightRAG storage implementations SAMpai uses. Leave as-is.
LIGHTRAG_KV_STORAGE=RedisKVStorage
LIGHTRAG_VECTOR_STORAGE=QdrantVectorDBStorage
LIGHTRAG_GRAPH_STORAGE=Neo4JStorage
LIGHTRAG_DOC_STATUS_STORAGE=RedisDocStatusStorage

# Neo4j (knowledge graph)
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=<your-neo4j-password>
NEO4J_DATABASE=neo4j

# Qdrant (vector store)
QDRANT_URL=http://localhost:6333

# Redis (KV + document status)
REDIS_URI=redis://localhost:6379

# ── Application database (PostgreSQL) ─────────────────────────────────────────
# Used by the SAMpai layer (users, classrooms, files, quizzes, chats, ...).
# Must match the running Postgres instance (compose `data` profile uses 5432).
APP_DATABASE_URL=postgresql+asyncpg://sampai:sampai@localhost:5432/sampai

# ── Authentication / app settings ─────────────────────────────────────────────
APP_JWT_SECRET=<generate-a-long-random-string>
APP_JWT_EXPIRE_MIN=1440
APP_CORS_ORIGINS=http://localhost:5173
APP_UPLOAD_MAX_MB=100
APP_ENGINE_IDLE_TTL=1800
APP_MAX_RESIDENT_ENGINES=8

# ── Cloudflare R2 (file storage, S3-compatible) ───────────────────────────────
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=<your-r2-access-key-id>
R2_SECRET_ACCESS_KEY=<your-r2-secret-access-key>
R2_BUCKET=sampai-files
R2_PRESIGN_TTL=3600

# ── Notes ─────────────────────────────────────────────────────────────────────
# - Docker store credentials (POSTGRES_*, NEO4J_*) for the compose `data` profile
#   can also be set here; see sampai/docker/.env.example.
# - MinerU backend variables are written automatically by
#   sampai/docker/scripts/mineru-autoselect.{sh,ps1} — do not set them by hand.
