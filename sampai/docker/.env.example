# Docker-stack overrides for the SAMpai compose files. Copy to `.env` in this dir,
# or rely on the repo-root .env (the `api` service loads ../../.env).
#
# The MinerU backend vars (MINERU_LOCAL_BACKEND / MINERU_LOCAL_IMAGE_ANALYSIS) are
# written automatically by scripts/mineru-autoselect.{sh,ps1} into mineru.generated.env
# — do not set them here.

# ── Store credentials (used by the compose `data` services) ──
POSTGRES_USER=sampai
POSTGRES_PASSWORD=sampai
POSTGRES_DB=sampai
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=please-change

# ── Parser images ──
# Pinned to the CPU builds already in use on this machine.
# For a GPU host, swap MINERU_IMAGE for an sglang/vllm mineru-api build + use the GPU overlay.
MINERU_IMAGE=mineru-cpu:latest
DOCLING_IMAGE=ghcr.io/docling-project/docling-serve-cpu:main
