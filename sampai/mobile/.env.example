# Backend base URL the app talks to (no trailing slash). All routes are under ${API_BASE}/api/sampai.
# Android emulator -> host machine: http://10.0.2.2:9621  (this is the default if unset)
# iOS simulator    -> http://localhost:9621
# Physical device  -> http://<your-LAN-IP>:9621  (e.g. http://192.168.1.100:9621)
# Production        -> https://<your-cloudflare-tunnel-domain>
EXPO_PUBLIC_API_BASE=http://10.0.2.2:9621
