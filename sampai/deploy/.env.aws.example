# SAMpai AWS demo environment.
# Copy to sampai/deploy/.env.aws on the EC2 instance with:
#   bash sampai/deploy/scripts/init-env.sh
#
# Never commit the generated .env.aws file.

############################
# Public edge
############################
SAMPAI_WEB_BIND=0.0.0.0
SAMPAI_WEB_PORT=8080

# Required only for Cloudflare Tunnel HTTPS mode.
# Create a tunnel in Cloudflare Zero Trust and paste the Docker token here.
CLOUDFLARED_TOKEN=REPLACE_CLOUDFLARED_TOKEN

############################
# Data service credentials
############################
POSTGRES_USER=sampai
POSTGRES_PASSWORD=REPLACE_POSTGRES_PASSWORD
POSTGRES_DB=sampai
POSTGRES_DATABASE=sampai

NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=REPLACE_NEO4J_PASSWORD

############################
# LightRAG storage backends
############################
WORKSPACE=sampai_demo
LIGHTRAG_KV_STORAGE=RedisKVStorage
LIGHTRAG_DOC_STATUS_STORAGE=RedisDocStatusStorage
LIGHTRAG_GRAPH_STORAGE=Neo4JStorage
LIGHTRAG_VECTOR_STORAGE=QdrantVectorDBStorage

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_WORKSPACE=sampai_demo
NEO4J_URI=bolt://neo4j:7687
QDRANT_URL=http://qdrant:6333
QDRANT_WORKSPACE=sampai_demo
REDIS_URI=redis://redis:6379
REDIS_WORKSPACE=sampai_demo

############################
# SAMpai app layer
############################
APP_DATABASE_URL=postgresql+asyncpg://sampai:REPLACE_POSTGRES_PASSWORD@postgres:5432/sampai
APP_JWT_SECRET=REPLACE_APP_JWT_SECRET
APP_JWT_EXPIRE_MIN=1440
APP_CORS_ORIGINS=*
APP_UPLOAD_MAX_MB=100
APP_ENGINE_IDLE_TTL=1800
APP_MAX_RESIDENT_ENGINES=4

############################
# API auth
############################
LIGHTRAG_API_KEY=REPLACE_LIGHTRAG_API_KEY
AUTH_ACCOUNTS=admin:REPLACE_ADMIN_PASSWORD
TOKEN_SECRET=REPLACE_TOKEN_SECRET
TOKEN_EXPIRE_HOURS=12
GUEST_TOKEN_EXPIRE_HOURS=2
WHITELIST_PATHS=/health,/api/*

############################
# LLM and embedding provider
############################
# OpenAI-compatible defaults are shown because they match the current SAMpai
# code paths, but any supported LightRAG binding can be used if the required
# env vars are filled.
LLM_BINDING=openai
LLM_BINDING_HOST=https://api.openai.com/v1
LLM_BINDING_API_KEY=REPLACE_LLM_API_KEY
LLM_MODEL=REPLACE_LLM_MODEL

EMBEDDING_BINDING=openai
EMBEDDING_BINDING_HOST=https://api.openai.com/v1
EMBEDDING_BINDING_API_KEY=REPLACE_EMBEDDING_API_KEY
EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_DIM=3072
EMBEDDING_TOKEN_LIMIT=8192
EMBEDDING_SEND_DIM=false
EMBEDDING_USE_BASE64=true

RERANK_BINDING=null
SUMMARY_LANGUAGE=English
MAX_ASYNC=3
MAX_PARALLEL_INSERT=2
EMBEDDING_FUNC_MAX_ASYNC=4
EMBEDDING_BATCH_NUM=10

############################
# Parser routing
############################
# Pre-ingested demo mode: prefer native/legacy and do not run parser services.
LIGHTRAG_PARSER=*:native-teP,*:legacy-R

# Live upload mode: start with "bash scripts/democtl.sh start-live" and change
# LIGHTRAG_PARSER to a docling route such as the one below. It keeps image
# analysis disabled so demo uploads do not require a configured VLM role.
# Add "i" only when VLM_PROCESS_ENABLE and the vlm role are configured.
# LIGHTRAG_PARSER=docx:docling-teR,pdf:docling-teR,pptx:docling-teR,xlsx:docling-teR,*:legacy-R
DOCLING_ENDPOINT=http://docling:5001
DOCLING_DO_OCR=true
DOCLING_FORCE_OCR=true

# MinerU is deliberately disabled for the AWS demo path.
MINERU_API_MODE=local
MINERU_LOCAL_ENDPOINT=
VLM_PROCESS_ENABLE=false

############################
# Cloudflare R2 object storage
############################
R2_ENDPOINT=REPLACE_R2_ENDPOINT
R2_ACCESS_KEY_ID=REPLACE_R2_ACCESS_KEY_ID
R2_SECRET_ACCESS_KEY=REPLACE_R2_SECRET_ACCESS_KEY
R2_BUCKET=REPLACE_R2_BUCKET
R2_PRESIGN_TTL=3600
